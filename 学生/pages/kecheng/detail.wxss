/* pages/kecheng/detail.wxss */

.mp{
  width:92%;
  margin:20rpx 4%;
  padding:20rpx;
  height: 320rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
}

.mpimg1{
  height: 290rpx;
  flex-shrink: 0;
  max-width: 30%;
}

.mpv1{
  padding:20rpx 30rpx;
  width: 100%;
  position: relative;
}

.mpname{
  font-size: 45rpx;
  font-weight: bold;
  letter-spacing: 30rpx;
}

.mpline{
  width:  100%;
  height: 6rpx;
  background-color: white;
  margin:10rpx 0;
}

.mplvsuo{
  font-size: 33rpx;
  padding:20rpx 0;
}

.mpbiaoqian{
  display: flex;
  flex-wrap: wrap;
  align-items:center;
  position: absolute;
  bottom:0;
  left:30rpx;
}

.mpbiaoqian text{
  font-size: 31rpx;
  margin-right: 20rpx;
  font-weight: bold;
}					


.zyrc{
  width: 94%;
  margin-left: 3%;
  margin-top: 30rpx;
  padding:30rpx;
  background-color: white;
  border-radius: 20rpx;
}

.zyrctitle{
  font-size: 42rpx;
  font-weight: bold;
}

.zyrctime{
  display: flex;
  align-items: center;
  font-size: 0;
  margin-top:30rpx;
}

.zyrctime image{
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.zyrctime view{
  font-size: 28rpx;
}


.cu-capsule > view{
  font-size:32rpx;
}

.cu-timeline{
  background-color: transparent;
}

.cu-timeline>.cu-item:not([class*="cuIcon-"])::before{
  background-color: transparent;
}					
					
					
					